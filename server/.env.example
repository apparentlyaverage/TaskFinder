# ── Database (Neon) ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://taskfinder_owner:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/taskfinder?sslmode=require

# ── JWT + Session ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-32-byte-random-hex-string
JWT_EXPIRES_IN=7d
SESSION_SECRET=generate-another-32-byte-random-hex-string

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# Local dev (Vite proxies port 3000 → 3001):
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# PRODUCTION — set this on Railway AND add the exact URI in Google Console:
# GOOGLE_CALLBACK_URL=https://api.relivr.co.za/auth/google/callback

# ── URLs ───────────────────────────────────────────────────────────────────────
# Canonical frontend origin — used for CORS and all OAuth/email redirects.
# PRODUCTION (Railway):  FRONTEND_URL=https://relivr.co.za
FRONTEND_URL=http://localhost:3000
# Optional extra allowed CORS origins (comma-separated) — e.g. the www host:
# CORS_EXTRA_ORIGINS=https://www.relivr.co.za
CORS_EXTRA_ORIGINS=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Transactional mail is sent via Resend. Leave RESEND_API_KEY blank in dev —
# emails are logged to console instead of sent. Verify your DOMAIN (relivr.co.za)
# at https://resend.com before going live; once the domain is verified, ANY
# address @relivr.co.za works as a sender (no per-address setup needed).
RESEND_API_KEY=
# Generic fallback sender (used if a category sender below is unset).
EMAIL_FROM=ReLivR <noreply@relivr.co.za>
# SUPPORT sender — security/auth mail (verify email, password reset). reply_to is
# set to SUPPORT_REPLY_TO so a user replying reaches a real, monitored inbox.
EMAIL_FROM_SUPPORT=ReLivR Support <support@relivr.co.za>
SUPPORT_REPLY_TO=support@relivr.co.za
# UPDATES sender — activity mail (notifications: task updates, message replies,
# bids, reviews; and the daily digest). Typically a no-reply address.
EMAIL_FROM_UPDATES=ReLivR Updates <updates@relivr.co.za>

# ── Payments (Paystack) ────────────────────────────────────────────────────────
# ZAR-native escrow + business subscription billing. Payments go live ~Month 2,
# so these may stay blank at launch — the server boots and warns, and /payments/*
# routes return an error until the secret key is set.
# Get keys at https://dashboard.paystack.com → Settings → API Keys & Webhooks.
# Use sk_test_/pk_test_ keys until you go live, then swap to sk_live_/pk_live_.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Set the webhook URL in the Paystack dashboard to:
#   https://api.relivr.co.za/payments/webhook

# ── Image uploads (Cloudinary) ───────────────────────────────────────────────
# Business owners upload photos straight from their device to Cloudinary; the
# server only mints a short-lived signature (POST /uploads/signature) — files
# never pass through Railway. Get these from https://cloudinary.com → Dashboard.
# Without them, /uploads/signature returns 503 and owners can still paste URLs.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: a SIGNED upload preset (Cloudinary → Settings → Upload → Add preset,
# Signing Mode = Signed). Use it to enforce allowed formats (jpg,png,webp,gif),
# a max file size, max dimensions, and an incoming f_auto,q_auto transform so the
# limits live in Cloudinary, not the browser. Leave blank to sign folder+timestamp only.
CLOUDINARY_UPLOAD_PRESET=
# Format whitelist, signed into every upload so it's enforced by Cloudinary even
# without a preset. Comma-separated; defaults to jpg,jpeg,png,webp,gif if unset.
CLOUDINARY_ALLOWED_FORMATS=

# ── Observability ──────────────────────────────────────────────────────────────
# Sentry error tracking DSN. Leave blank — errors go to structured logs until set.
# Create a project at https://sentry.io and paste the DSN here.
SENTRY_DSN=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
