# ── Backend URL ────────────────────────────────────────────────────────────────
# PRODUCTION (set in Vercel → Project → Settings → Environment Variables):
#   VITE_API_URL=https://api.relivr.co.za
# Local dev: leave blank — Vite proxies relative paths to localhost:3001 automatically.
VITE_API_URL=

# ── Cloudflare Turnstile (bot check on the landing forms) ──────────────────────
# Site key (public, pairs with the server's TURNSTILE_SECRET). Leave blank — the
# widget doesn't render and the Cloudflare script never loads until set.
VITE_TURNSTILE_SITE_KEY=
