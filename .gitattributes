# Force LF line endings for all text files
* text=auto eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sql  text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.svg  text eol=lf
Dockerfile text eol=lf
*.sh   text eol=lf
*.bat  text eol=crlf
*.ps1  text eol=crlf
