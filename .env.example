# Root .env.example — top-level reference. The authoritative copy for each
# service is in server/.env.example and frontend/.env.example.

# ── Database (Neon) ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://taskfinder_owner:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/taskfinder?sslmode=require

# ── JWT + Session ──────────────────────────────────────────────────────────────
JWT_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_EXPIRES_IN=7d
SESSION_SECRET=generate-another-one

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (Resend) ─────────────────────────────────────────────────────────────
EMAIL_FROM=ReLivR <noreply@relivr.co.za>
RESEND_API_KEY=

# ── Observability ──────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
