# PostgreSQL
POSTGRES_USER=taskfinder
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=taskfinder
DATABASE_URL=postgresql://taskfinder:change_me_postgres@localhost:5432/taskfinder

# Redis
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@localhost:6379

# RabbitMQ
RABBITMQ_USER=taskfinder
RABBITMQ_PASSWORD=change_me_rabbitmq
