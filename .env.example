# JWT
JWT_SECRET=replace_with_32_char_minimum_random_string
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PLATFORM_FEE_PERCENT=0.10

# App
CLIENT_URL=http://localhost:3000
NODE_ENV=development
GATEWAY_PORT=8080

# Service URLs
